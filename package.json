{
  "name": "gameevaluate-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix --cache",
    "lint:check": "eslint . --cache",
    "lint:check:base": "eslint . --cache --rule \"no-unused-vars: off\" --rule \"vue/multi-word-component-names: off\"",
    "test:gate": "npm run test:unit --if-present",
    "quality:check": "npm run lint:check:base && npm run test:gate && npm run build",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.13.4",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.1",
    "page-agent": "^1.6.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "~10.7.0",
    "globals": "^17.0.0",
    "prettier": "3.8.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.3.1",
    "vite-plugin-mock-dev-server": "^2.1.1",
    "vite-plugin-vue-devtools": "^8.0.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
